{
  "name": "rog-monitor",
  "version": "20.0.0",
  "description": "ROG Monitor desktop app (Electron shell over the Python sensor core)",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "license": "MIT",
  "devDependencies": {
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3"
  },
  "productName": "ROG Monitor",
  "build": {
    "appId": "org.rogmonitor.app",
    "productName": "ROG Monitor",
    "directories": { "output": "dist" },
    "files": ["**/*", "!dist/**"],
    "extraResources": [
      { "from": "../src", "to": "src" },
      { "from": "../scripts", "to": "scripts" },
      { "from": "../systemd", "to": "systemd" },
      { "from": "../VERSION", "to": "VERSION" },
      { "from": "../requirements.txt", "to": "requirements.txt" }
    ],
    "linux": {
      "target": ["AppImage"],
      "icon": "assets/icon.png",
      "category": "Utility",
      "synopsis": "Armoury Crate for Linux — thermals, power, fans, RGB, overlay"
    }
  }
}
