{
  "_comment": "ROG Monitor device profiles. Each entry describes the power/clock control surface for a specific laptop model.",
  "_custom_override": "Create ~/.config/rog-monitor/device.json with the same structure to override the active profile. The 'id' field must match the auto-detected device or be 'custom'.",
  "_clock_offset_note": "base_clock_offset and mem_clock_offset ranges here are the SAFE UI defaults. The absolute driver limits (NVML) override these at runtime (core: -1000..+1000, mem: -2000..+6000). The UI shows the safe range and requires double consent to exceed it.",
  "_profile_power_note": "profile_power maps each system profile (quiet/balanced/performance) to a set of power limits {pl1, pl2, dynamic_boost, thermal_target}. These are applied automatically when the profile changes (alongside the fan curve), via the same pkexec path as manual changes (apply-power-control.sh), which re-clamps every value to the live firmware min/max (DOUBLE CLAMP). All values here are already inside each control's safe min..max in this file; quiet is the lowest (cool & silent), performance is the factory safe ceiling. 'power-saver' is accepted as an alias of 'quiet' (PPD naming). The 'est_thermal' field per profile documents the estimated steady-state temperature band under sustained gaming load on this model; it is informational only and not enforced.",
  "devices": [
    {
      "id": "asus-2023-hx-rtx4060-16",
      "name": "ASUS 2023 16-inch HX/RTX laptop profile",
      "friendly_name": "ASUS calibrated gaming laptop",
      "dmi_match": "G614JV",
      "dmi_field": "/sys/class/dmi/id/product_name",
      "calibrated": true,
      "profile_power": {
        "quiet": {
          "pl1": 35,
          "pl2": 45,
          "dynamic_boost": 5,
          "thermal_target": 75,
          "est_thermal": "Conservative quiet profile for lower fan noise and battery use."
        },
        "balanced": {
          "pl1": 80,
          "pl2": 110,
          "dynamic_boost": 15,
          "thermal_target": 82,
          "est_thermal": "Balanced local profile for mixed desktop/gaming use."
        },
        "performance": {
          "pl1": 140,
          "pl2": 175,
          "dynamic_boost": 25,
          "thermal_target": 87,
          "est_thermal": "Firmware ceiling profile for AC power and maximum performance."
        }
      },
      "controls": [
        {
          "key": "pl1",
          "attr": "ppt_pl1_spl",
          "label_es": "CPU PL1 (sostenida)",
          "label_en": "CPU PL1 (sustained)",
          "unit": "W",
          "min": 28,
          "max": 140,
          "default": 140,
          "writable": true,
          "reason": null
        },
        {
